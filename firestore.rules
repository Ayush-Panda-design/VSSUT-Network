rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // USERS — readable by signed-in users; writable only by admin (except a user creating their own base profile).
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        // user signing up creates their own doc with role 'user'
        (request.auth.uid == userId && request.resource.data.role == 'user')
        || isAdmin()
      );
      allow update, delete: if isAdmin();
    }

    // CHAT — signed-in users can read & post; only admin can delete/edit.
    match /chatRooms/{roomId}/messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() < 2000;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
